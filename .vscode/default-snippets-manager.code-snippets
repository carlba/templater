    "body": [
      "export async function ensureDir(dir: string) {",
      "  try {",
      "    await fs.mkdir(dir, { recursive: true });",
      "  } catch (err: unknown) {",
      "    logger.error({ err }, `Failed to ensure directory exists: \\${dir}`);",
      "    throw err;",
      "  }",
      "}",
    ],
  },
}
