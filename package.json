{
  "name": "templater",
  "description": "A templater for Typescript project to begin with",
  "version": "0.0.1",
  "private": false,
  "license": "UNLICENSED",
  "type": "module",
  "author": "carlba",
  "homepage": "https://github.com/carlba/templater",
  "bugs": {
    "url": "https://github.com/carlba/templater"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:carlba/templater"
  },
  "scripts": {
    "build": "tsc",
    "start": "node --env-file-if-exists dist/index.js",
    "start:dev": "tsx --env-file-if-exists=.env --watch src/index.ts",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dependency:update": "npx ncu -u -x eslint",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "build-watch": "tsc --watch",
    "linux:install": "docker run --rm --platform linux/amd64 -v \"$PWD\":/app -w /app node:24-bullseye npm install",
    "linux:ci": "docker run --rm --platform linux/amd64 -v \"$PWD\":/app -w /app node:24-bullseye bash -lc \"npm ci && npm run lint && npm test && npm run build\""
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.6.0",
    "@types/split2": "^4.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv": "^17.2.3",
    "nodemon": "^3.1.11",
    "npm-check-updates": "^21.0.3",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^12.1.0",
    "commander": "^12.1.0",
    "deepmerge-ts": "^7.0.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "split2": "^4.2.0",
    "type-fest": "^4.18.3",
    "zod": "^4.3.6"
  },
  "bin": {
    "templater": "./dist/index.js"
  }
}
