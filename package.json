{
  "name": "templater",
  "description": "A templater for Typescript project to begin with",
  "version": "0.0.1",
  "private": false,
  "license": "UNLICENSED",
  "type": "module",
  "author": "carlba",
  "homepage": "https://github.com/carlba/templater",
  "bugs": {
    "url": "https://github.com/carlba/templater"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:carlba/templater"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:dev": "nodemon -r dotenv/config -q src/index.ts",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dependency:update": "npx ncu -u -x eslint",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.3",
    "@types/node": "^25.0.3",
    "@types/split2": "^4.2.3",
    "dotenv": "^17.2.3",
    "nodemon": "^3.1.11",
    "npm-check-updates": "^19.3.1",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^12.1.0",
    "commander": "^12.1.0",
    "deepmerge-ts": "^7.0.2",
    "pino": "^10.1.1",
    "pino-pretty": "^13.1.3",
    "split2": "^4.2.0",
    "type-fest": "^4.18.3"
  },
  "bin": {
    "templater": "./dist/index.js"
  }
}
